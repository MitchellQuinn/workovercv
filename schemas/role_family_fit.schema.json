{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkOverCV Role Family Fit",
  "type": "object",
  "required": ["role_family_fit"],
  "properties": {
    "role_family_fit": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role_family",
          "why_discuss",
          "behaviour_fit",
          "likely_contribution",
          "interview_probes",
          "confidence",
          "caveats",
          "supporting_signal_ids",
          "limiting_gap_ids"
        ],
        "properties": {
          "role_family": { "type": "string", "minLength": 1 },
          "why_discuss": { "type": "string", "minLength": 1 },
          "behaviour_fit": { "type": "string", "minLength": 1 },
          "likely_contribution": { "type": "string", "minLength": 1 },
          "interview_probes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "confidence": { "enum": ["low", "medium", "high"] },
          "caveats": { "type": "string", "minLength": 1 },
          "supporting_signal_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "limiting_gap_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
