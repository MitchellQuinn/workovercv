{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkOverCV Repository Inventory",
  "type": "object",
  "required": ["candidate", "generated_at", "repositories"],
  "properties": {
    "candidate": {
      "type": "object",
      "required": ["type", "url", "username"],
      "properties": {
        "type": { "enum": ["github_profile", "local_path"] },
        "url": { "type": "string", "minLength": 1 },
        "username": { "type": "string", "minLength": 1 },
        "display_name": { "type": ["string", "null"] },
        "public_repos": { "type": ["integer", "null"] },
        "path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "generated_at": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "properties": {
        "type": { "enum": ["github_api", "local_path"] },
        "authenticated": { "type": "boolean" },
        "path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repo_id", "name", "url", "visibility", "selected_for_review", "selection_reason"],
        "properties": {
          "repo_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "clone_url": { "type": ["string", "null"] },
          "local_path": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "primary_language": { "type": ["string", "null"] },
          "visibility": { "enum": ["public", "private", "internal", "local", "unknown"] },
          "selected_for_review": { "type": "boolean" },
          "selection_reason": { "type": "string", "minLength": 1 },
          "default_branch": { "type": ["string", "null"] },
          "last_updated": { "type": ["string", "null"] },
          "stars": { "type": "integer", "minimum": 0 },
          "forks": { "type": "integer", "minimum": 0 },
          "watchers": { "type": "integer", "minimum": 0 },
          "fork": { "type": "boolean" },
          "archived": { "type": "boolean" },
          "license": { "type": ["string", "null"] },
          "release_status": { "type": "string" },
          "readme_presence": { "type": "string" },
          "test_presence": { "type": "string" },
          "documentation_presence": { "type": "string" },
          "selection_score": { "type": "integer" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
