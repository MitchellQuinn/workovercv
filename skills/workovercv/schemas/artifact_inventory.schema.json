{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkOverCV Artifact Inventory",
  "type": "object",
  "required": ["generated_at", "artifacts"],
  "properties": {
    "generated_at": { "type": "string", "minLength": 1 },
    "source_scope": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "repo_id", "path", "artifact_type", "size_estimate", "likely_signal_value"],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 1 },
          "repo_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "artifact_type": {
            "enum": [
              "CI_workflow",
              "README",
              "model_card",
              "failure_analysis",
              "architecture_document",
              "test_file",
              "training_script",
              "inference_script",
              "evaluation_script",
              "run_manifest",
              "data_manifest",
              "configuration_file",
              "inventory_summary",
              "work_chronology",
              "notebook_source",
              "source_code",
              "technical_writeup"
            ]
          },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "size_estimate": { "enum": ["small", "medium", "large"] },
          "likely_signal_value": { "enum": ["low", "medium", "high"] },
          "sha256": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
